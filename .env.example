# ── FIDO Loans Environment Variables ──
# Copy this file to ".env" and fill in your values.

# Telegram Bot Token – get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwxYZ

# Telegram Chat / Group / Channel ID to receive loan submissions
# For a private chat: open Telegram Web, go to the chat,
# the URL will show a number like -100xxxxxxxxxx → that is your CHAT_ID
CHAT_ID=-100123456789

# HTTP port for local server (default 3000)
PORT=3000
